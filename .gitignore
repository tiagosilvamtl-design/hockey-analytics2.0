# Secrets — never commit
.env
.env.local
.env.*.local
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc
*.pyo
*.egg
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Virtual envs
.venv/
venv/
env/
ENV/

# Data caches — never commit local stores
*.sqlite
*.sqlite-journal
*.db
*.db-journal
.lemieux/

# Node (docx build)
node_modules/
npm-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
.ipynb_checkpoints/

# Editors
.vscode/
.idea/
*.swp

# Local reports output — regenerate from scripts, don't commit
reports/output/*.sqlite
reports/output/*.log

# Docs build artifacts
site/
build/
dist/

# Research raw notes (scratch, do not commit) — but DO commit structured
# research-game skill outputs (claims yamls + lineups yamls).
research/*
!research/*_claims.yaml
!research/*_lineups.yaml
reearch/

# Local Claude Code settings (per-machine; never commit)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/scheduled_tasks/

# Internal progress / planning notes — never publish
plans/
PROGRESS*.md
PROGRESS_*.md
NEXT_STEPS*.md
TODO_*.md

# Google OAuth credentials and tokens (NEVER commit)
google-credentials.json
google-token.json
.lemieux/
node_modules/

# Run logs from background scouting / biometrics jobs
*_run.log

# Exported artifact bundles (generated by tools/export_derived_artifacts.py)
lemieux_derived_*.zip

# Deck workspace — internal slides, not part of the public framework
deck/

# LinkedIn / social-media post drafts — never commit, edit on Drive instead
lemieux_linkedin_*
*_linkedin_drafts.docx
